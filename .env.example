# Copy this file to .env and fill your real values.

# ---------------------------
# EmailJS configuration
# ---------------------------
# Example: https://api.emailjs.com/api/v1.0/email/send
EMAILJS_API_URL=https://api.emailjs.com/api/v1.0/email/send
# Fill from your EmailJS dashboard
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
# Optional: private key / access token (if your EmailJS setup uses it)
EMAILJS_PRIVATE_KEY=
EMAILJS_APP_NAME=Doctor Appointment App

# ---------------------------
# Google OAuth configuration
# ---------------------------
# Fill all 4 values from your Google Cloud OAuth credentials.
# 1) Web client ID (OAuth client type: Web application)
GOOGLE_OAUTH_WEB_CLIENT_ID=
# 2) Android client ID (OAuth client type: Android)
GOOGLE_OAUTH_ANDROID_CLIENT_ID=
# 3) Android package name (must match app build.gradle applicationId)
GOOGLE_OAUTH_ANDROID_PACKAGE_NAME=com.example.doctor_appointment_app
# 4) Android SHA-1 fingerprint (debug/release keystore you use to run app)
GOOGLE_OAUTH_ANDROID_SHA1=
